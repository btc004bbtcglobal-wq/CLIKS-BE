# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# DB_TYPE=sqlite          # default; no extra config needed
# DB_TYPE=postgres
# DATABASE_URL=postgresql://user:password@localhost:5432/books_finance

# ── Authentication ────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_32chars+
JWT_REFRESH_SECRET=change_me_to_a_different_long_random_secret

# ── Redis (optional — leave REDIS_ENABLED unset or false to disable) ─────────
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379

# ── Observability ─────────────────────────────────────────────────────────────
LOG_LEVEL=info                  # trace | debug | info | warn | error | fatal
LOG_REQUESTS=true               # set to "false" to silence request logs
SLOW_THRESHOLD_MS=500           # requests slower than this are logged as [SLOW]

# ── Sentry (error tracking — leave SENTRY_DSN blank to disable) ──────────────
SENTRY_DSN=                     # e.g. https://abc123@o0.ingest.sentry.io/000000
SENTRY_ENVIRONMENT=development  # production | staging | development
SENTRY_TRACES_RATE=0.1          # 0.0 = no tracing, 1.0 = trace everything
